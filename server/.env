# FarmLink Environment Variables
# Copy this to .env and fill in your values

PORT=5001
MONGODB_URI=mongodb://localhost:27017/farmlink
JWT_SECRET=mysecretkey123
JWT_EXPIRES_IN=7d

# Admin credentials (set on first run)
ADMIN_EMAIL=admin@farmlink.com
ADMIN_PASSWORD=changeme123

# Logistics Switch — set to "true" to activate Phase 2 (enterprise courier APIs)
LOGISTICS_ENTERPRISE_ENABLED=false

# Phase 2 (future) — Ekart / Amazon Logistics
EKART_API_KEY=
EKART_API_URL=
AMAZON_LOGISTICS_API_KEY=
AMAZON_LOGISTICS_API_URL=
